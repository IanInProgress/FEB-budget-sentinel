## Slack
# Slash command: /purchase
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_SIGNING_SECRET=REPLACE_ME

## Google Sheets
# Spreadsheet ID from URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=REPLACE_ME

# Provide ONE of the following service account credential sources:
# 1) Path to service account JSON file
GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/to/service-account.json
#
# 2) Raw JSON (escaped) in an env var (useful for deployment)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

## App behavior
LOG_LEVEL=INFO

# Optional JSON mapping of subteam aliases -> tab name.
# Keys are user-entered values; values are the canonical Google Sheet tab names.
# SUBTEAM_ALIASES_JSON={"elec":"Electronics","electronics":"Electronics","susp":"Suspension","suspension":"Suspension"}

# Optional fuzzy suggestion threshold (0-100). Used only for suggestions.
FUZZY_SUGGESTION_THRESHOLD=84

## Server
PORT=3000
SLACK_COMMANDS_PATH=/slack/commands
